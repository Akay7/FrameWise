{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "main.py (no interface)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "CAPTION_PROVIDER": "gemini",
        "GEMINI_API_KEY": "",
        "INPUT_PATH": "${workspaceFolder}/sample_tasks.json",
        "OUTPUT_PATH": "${workspaceFolder}/results.json"
      }
    },
    {
      "name": "app.py (Gradio demo)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        // Defaults to 1 in app.py to avoid OOM on Render's 512MB free tier;
        // raised here since local runs have real headroom.
        "DEMO_MAX_PARALLEL_TASKS": "4"
      }
    },
    {
      "name": "Python: Current file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
